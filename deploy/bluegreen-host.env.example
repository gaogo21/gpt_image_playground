# Remote image tags per color. The deploy script updates the standby color tag
# before replacing that container.
APP_BLUE_IMAGE=image:bootstrap-blue
APP_GREEN_IMAGE=image:bootstrap-green

# Fixed blue/green runtime contract on the gptch.cloud host.
BLUE_CONTAINER=image-blue
GREEN_CONTAINER=image-green-amd64
BLUE_PORT=3200
GREEN_PORT=3201

# Frontend runtime defaults for the static SPA container.
DEFAULT_API_URL=https://gptch.cloud/v1
ENABLE_API_PROXY=false
LOCK_API_PROXY=false
HOST=0.0.0.0
PORT=80
