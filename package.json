{
  "name": "gpt-image-playground",
  "private": true,
  "version": "0.6.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:canvas": "cd vendor/infinite-canvas/web && rm -rf .next && NEXT_PUBLIC_DOC_URL=http://localhost:5173/manual/index.html ./node_modules/.bin/next dev -H 0.0.0.0 -p 3002",
    "dev:all": "sh -c 'trap \"kill 0\" INT TERM EXIT; npm run dev & npm run dev:canvas & wait'",
    "build:manual": "node scripts/build-manual.mjs",
    "mock:api": "node scripts/mock-image-api.mjs",
    "build": "npm run build:manual && tsc -b && vite build",
    "deploy:cf": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.0",
    "@streamdown/math": "^1.0.2",
    "@xyflow/react": "^12.11.1",
    "core-js": "^3.49.0",
    "fflate": "^0.8.2",
    "katex": "^0.16.47",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "zustand": "^5.0.5"
  },
  "overrides": {
    "mdast-util-gfm-autolink-literal": "2.0.0",
    "dompurify": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "marked": "^17.0.6",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.96.0"
  }
}
